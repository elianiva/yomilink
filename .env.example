# Database Mode: "remote" (Turso/LibSQL) or "local" (SQLite file)
DATABASE_MODE=remote

# Database (Turso/LibSQL) - used when DATABASE_MODE=remote
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Local SQLite - used when DATABASE_MODE=local
# TURSO_DATABASE_URL=file:./data/yomilink.sqlite

# Sentry (Error Tracking) - optional for local development
VITE_SENTRY_DSN=https://your-sentry-dsn

# Application
SITE_URL=https://your-domain.com
NODE_ENV=production

# Authentication (Better Auth)
BETTER_AUTH_URL=https://your-domain.com
BETTER_AUTH_SECRET=your-secret-key-min-32-characters-long

# Build-time only (not needed in production runtime)
# SENTRY_AUTH_TOKEN=your-sentry-build-token
