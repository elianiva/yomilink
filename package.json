{
	"name": "yomilink",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "NODE_ENV='development' vp dev",
		"spotlight": "npx @spotlightjs/spotlight",
		"build": "vp build",
		"serve": "vp preview",
		"test": "vp test run -c vitest.ui.config.ts",
		"test:ui": "vp test run -c vitest.ui.config.ts",
		"test:watch": "vp test run -c vitest.ui.config.ts --watch",
		"test:ui:watch": "vp test run -c vitest.ui.config.ts --watch",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "tsx --env-file=.env scripts/seed/index.ts",
		"coverage": "vp test run --coverage",
		"coverage:ui": "vp test run --coverage --coverage.ui",
		"format": "vp fmt --write ./src/**/*",
		"lint": "vp lint --fix ./src/**/*",
		"typecheck": "tsgo --noEmit",
		"cf-typegen": "wrangler types",
		"deploy:check": "vp run typecheck && vp run lint && vp run test",
		"deploy": "vp run deploy:check && wrangler deploy",
		"deploy:staging": "vp run deploy:check && wrangler deploy --env staging",
		"ui": "npx shadcn@canary",
		"effect:prepare": "effect-language-service patch",
		"prepare": "vp config"
	},
