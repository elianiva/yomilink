{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "yomilink",
	"compatibility_date": "2025-09-02",
	"compatibility_flags": ["nodejs_compat"],
	"workers_dev": true,
	"preview_urls": true,
	"observability": {
		"logs": {
			"enabled": true,
			"invocation_logs": true
		}
	},
	"main": "./src/server.ts",
	"r2_buckets": [
		{
			"binding": "MATERIAL_IMAGES",
			"bucket_name": "yomilink-materials"
		}
	]
}
